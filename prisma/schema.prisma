generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  name     String
  password String
  role     UserRole @default(USER)
  posts    Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

model Post {
  id                   String     @id @default(uuid())
  title                String
  slug                 String     @unique
  status               StatusEnum
  featuredImage        String?
  featuredImageTitle   String?
  featuredImageCaption String?
  content              String
  seoTitle             String?
  seoDescription       String?
  category             String?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // category   Category? @relation(fields: [categoryId], references: [id])
  // categoryId String?
}

enum StatusEnum {
  DRAFT
  PUBLISHED
}

// model Category {
//   id    String @id @default(uuid())
//   name  String @unique
//   posts Post[]
// }

model Form {
  id              String      @id @default(uuid())
  name            String
  triggerType     TriggerType
  bannerImage     String?
  thankYouMessage String?
  status          FormStatus  @default(ACTIVE)

  targetEmails  String[] // native postgres array
  assignedPages String[] // native postgres array

  fields      FormField[]
  submissions FormSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormField {
  id     String @id @default(uuid())
  form   Form   @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId String

  label    String
  type     FieldType
  required Boolean   @default(false)

  options String[]

  createdAt DateTime @default(now())
}

model FormSubmission {
  id   String @id @default(uuid())
  form Form   @relation(fields: [formId], references: [id], onDelete: Cascade)

  formId String

  data Json

  createdAt DateTime @default(now())
}

enum TriggerType {
  EMBED
  POPUP_LOAD
  POPUP_SCROLL
  POPUP_TIME
}

enum FormStatus {
  ACTIVE
  INACTIVE
}

enum FieldType {
  TEXT
  EMAIL
  TEXTAREA
  NUMBER
  SELECT
  PHONE
  CHECKBOX
}
